# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup script for UN*X systems
# ----------------------------------------------------------------------------

if [ -z "$MAVEN_SKIP_RC" ]; then
  [ -f /usr/local/etc/mavenrc ] && . /usr/local/etc/mavenrc
  [ -f /etc/mavenrc ] && . /etc/mavenrc
  [ -f "$HOME/.mavenrc" ] && . "$HOME/.mavenrc"
fi

# OS specific support
cygwin=false
darwin=false
mingw=false
case "$(uname)" in
  CYGWIN*) cygwin=true ;;
  MINGW*)  mingw=true  ;;
  Darwin*) darwin=true  ;;
esac

# Resolve links and find project base dir
PRG="$0"
while [ -h "$PRG" ]; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=$(dirname "$PRG")/"$link"
  fi
done
SAVED="$(pwd)"
cd "$(dirname "$PRG")/" >/dev/null
APP_HOME="$(pwd -P)"
cd "$SAVED" >/dev/null

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$APP_HOME}"
export MAVEN_PROJECTBASEDIR

MAVEN_OPTS="$(concat_lines "$MAVEN_PROJECTBASEDIR/.mvn/jvm.config") $MAVEN_OPTS"

# Read maven.config
if [ -f "$MAVEN_PROJECTBASEDIR/.mvn/maven.config" ]; then
  MAVEN_CONFIG="$(cat "$MAVEN_PROJECTBASEDIR/.mvn/maven.config")"
fi

# Find Maven wrapper jar
wrapperJarPath="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

if [ ! -f "$wrapperJarPath" ]; then
  wrapperUrl=$(grep 'wrapperUrl' "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties" 2>/dev/null | cut -d'=' -f2-)
  if [ -z "$wrapperUrl" ]; then
    wrapperUrl="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
  fi
  if command -v wget > /dev/null; then
    wget -q -O "$wrapperJarPath" "$wrapperUrl" 2>/dev/null
  elif command -v curl > /dev/null; then
    curl -sL -o "$wrapperJarPath" "$wrapperUrl" 2>/dev/null
  else
    echo "Error: Could not find wget or curl to download Maven wrapper." >&2
    exit 1
  fi
fi

# Find Java
if [ -n "$JAVA_HOME" ]; then
  JAVACMD="$JAVA_HOME/bin/java"
  if [ ! -x "$JAVACMD" ]; then
    echo "Error: JAVA_HOME is set but java not found at $JAVACMD" >&2
    exit 1
  fi
else
  JAVACMD="$(command -v java)"
  if [ -z "$JAVACMD" ]; then
    echo "Error: JAVA_HOME is not set and java not found in PATH." >&2
    exit 1
  fi
fi

# Build classpath
CLASSWORLDS_JAR=""
distributionUrl=$(grep 'distributionUrl' "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties" 2>/dev/null | cut -d'=' -f2-)

exec "$JAVACMD" \
  $MAVEN_OPTS \
  -classpath "$wrapperJarPath" \
  org.apache.maven.wrapper.MavenWrapperMain \
  $MAVEN_CONFIG \
  "$@"
